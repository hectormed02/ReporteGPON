{
  "buildCommand": "echo 'No build needed'",
  "installCommand": "echo 'No dependencies'",
  "outputDirectory": ".",
  "framework": "static",
  "env": {
    "VERCEL_ANALYTICS_ID": ""
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
